class TreeNode:
    def __init__(self, data):
        self.data = data
        self.children = []
        self.parent = None

    def add_child(self, child):
        child.parent = self
        self.children.append(child)

def print_tree(node, level=0, indent=""):
    print(node.data if level == 0 else "")
    for child in node.children:
        indent_child = indent + ("└── " if child == node.children[-1] else "├── ")
        print(indent_child + str(child.data))
        print_tree(child,level + 1,indent + ("    " if child == node.children[-1] else "│   "))
